{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dissertator",
  "version": "0.6.0",
  "identifier": "com.dissertator.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev:web",
    "beforeBuildCommand": "bun run build && bun run stage:resources"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dissertator",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/dissertator-sidecar"
    ],
    "resources": {
      "resources/native": "native",
      "resources/granite-embedding-97m-multilingual-r2": "granite-embedding-97m-multilingual-r2"
    }
  }
}
